          "name": "Create Teacher",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200 or 201\", function () {\r",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);\r",
                  "});\r",
                  "\r",
                  "let requestBody = JSON.parse(pm.request.body.raw);\r",
                  " responseBody = pm.response.json();\r",
                  "\r",
                  "// teacherId validation\r",
                  "pm.test(\"Teacher ID matches request\", function () {\r",
                  "    pm.expect(responseBody.teacherId).to.eql(requestBody.teacherId);\r",
                  "});\r",
                  "\r",
                  "// name validation\r",
                  "pm.test(\"Name matches request\", function () {\r",
                  "    pm.expect(responseBody.name).to.eql(requestBody.name);\r",
                  "});\r",
                  "\r",
                  "// email validation\r",
                  "pm.test(\"Email matches request\", function () {\r",
                  "    pm.expect(responseBody.email).to.eql(requestBody.email);\r",
                  "});\r",
                  "\r",
                  "// department validation\r",
                  "pm.test(\"Department matches request\", function () {\r",
                  "    pm.expect(responseBody.department).to.eql(requestBody.department);\r",
                  "});\r",
                  "\r",
                  "// designation validation\r",
                  "pm.test(\"Designation matches request\", function () {\r",
                  "    pm.expect(responseBody.designation).to.eql(requestBody.designation);\r",
                  "});\r",
                  "\r",
                  "// save teacherId for next APIs\r",
                  "pm.environment.set(\"teacherId\", responseBody.teacherId);\r",
                  "pm.collectionVariables.set(\"teacherId\", responseBody.teacherId);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
