        {
          "name": "Get All Teachers",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// 1️⃣ Status code check\r",
                  "pm.test(\"Status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "\r",
                  "//  Schema validation \r",
                  "pm.test(\"Validate teacher object schema\", function () {\r",
                  "    const teachers = pm.response.json();\r",
                  "    if (teachers.length > 0) {\r",
                  "        const teacher = teachers[0];\r",
                  "        pm.expect(teacher).to.have.property(\"name\").that.is.a(\"string\");\r",
                  "        pm.expect(teacher).to.have.property(\"email\").that.is.a(\"string\");\r",
                  "        pm.expect(teacher).to.have.property(\"department\").that.is.a(\"string\");\r",
                  "        pm.expect(teacher).to.have.property(\"teacherId\").that.is.a(\"number\");\r",
                  "        pm.expect(teacher).to.have.property(\"designation\").that.is.a(\"string\");\r",
                  "    }\r",
                  "});\r",
                  "\r",
                  "// 4️⃣ Check if created teacher exists in list\r",
                  "pm.test(\"Created teacher exists in list\", function () {\r",
                  "    const teachers = pm.response.json();\r",
                  "    const teacherId = pm.environment.get(\"teacherId\");\r",
                  "    const exists = teachers.some(t => t.teacherId == teacherId);\r",
                  "    pm.expect(exists).to.be.true;\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
