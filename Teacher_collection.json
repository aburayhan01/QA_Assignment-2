              "listen": "test",
              "script": {
                "exec": [
                  "// Status 200\r",
                  "pm.test(\"Status code is 200\", () => {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "\r",
                  "// Department filter \r",
                  "pm.test(\"Department filter works\", () => {\r",
                  "    const teachers = pm.response.json();\r",
                  "    if(teachers.length > 0){\r",
                  "        teachers.forEach(t => pm.expect(t.department).to.eql(\"CSE\"));\r",
                  "    }\r",
                  "});\r",
                  "\r",
                  "// Email filter \r",
                  "pm.test(\"Email filter works\", () => {\r",
                  "    const teachers = pm.response.json();\r",
                  "    const email = pm.collectionVariables.get(\"teacherEmail\");\r",
                  "    if(email){\r",
                  "        const found = teachers.some(t => t.email == email);\r",
                  "        pm.expect(found).to.be.true;\r",
                  "    }\r",
                  "});"
